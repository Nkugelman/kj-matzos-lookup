# Leave empty for local dev — Vite proxies /api → http://localhost:5041
# VITE_API_BASE_URL=

# Optional: override proxy target (API must expose CORS if you set a full URL here)
# VITE_API_PROXY_TARGET=http://localhost:5041

# Production build: set to your deployed API origin, e.g. https://kiosk-api.example.com
# VITE_API_BASE_URL=https://kiosk-api.example.com
